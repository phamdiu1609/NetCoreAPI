@model IEnumerable<KhachHang>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Ten)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Ten)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.KhachHangId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.KhachHangId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.KhachHangId">Delete</a>
                <a asp-action="DonHangDaMua" asp-route-id="@item.KhachHangId"class="btn btn-info"> Xem đơn hàng </a>
            </td>
        </tr>
}
    </tbody>
</table>
